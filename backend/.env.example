# ─── General ──────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=info

# ─── Trading ──────────────────────────────────────────────────────
# Set to "false" ONLY when you are ready for real trading
PAPER_TRADING=true

# ─── XPR Network ──────────────────────────────────────────────────
XPR_RPC=https://testnet.xprnetwork.org
XPR_CHAIN_ID=21dcae42c0182200e93f954a074011f9048a7f6c33f6f6a63ad52aeea7caa024

# ─── Anthropic (AI agents) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Exchange API (for price data) ────────────────────────────────
# Alcor DEX — no key needed (public API)
# For CEX price feed: add your key here
EXCHANGE_API_KEY=

# ─── Sentry (error tracking) ──────────────────────────────────────
SENTRY_DSN=
