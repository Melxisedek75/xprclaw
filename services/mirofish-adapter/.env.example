# XPRClaw MiroFish Adapter Configuration

# FastAPI
LOG_LEVEL=info

# MiroFish backend (where the Flask app runs)
MIROFISH_BASE_URL=http://localhost:5001

# LLM provider
# Options: openai, anthropic, qwen, ollama
LLM_PROVIDER=anthropic
LLM_API_KEY=your_api_key_here
LLM_MODEL=claude-3-sonnet-20240229

# Zep Cloud (long-term agent memory)
ZEP_API_KEY=
ZEP_PROJECT_ID=

# D1 Database (Cloudflare)
CF_ACCOUNT_ID=b457272dab63e8b60c2f939e7e55be9a
CF_API_TOKEN=
D1_DATABASE_ID=948f767e-ff2c-4df0-8798-824ac98d2927
D1_CACHE_TABLE=mirofish_cache

# Persona set delivery
# Options: hardcoded, yaml
PERSONA_DELIVERY=hardcoded
PERSONA_YAML_PATH=

# Cache eviction strategy
# Options: cron, on_demand, lru
CACHE_EVICTION_MODE=lru
CACHE_MAX_AGE_SECONDS=3600

# Simulation parameters
SIM_TIMEOUT_SECONDS=300
SIM_MAX_AGENTS=50

# Dev/test mode
ENV=development
